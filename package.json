{
	"name": "obsidian-remarkable-sync",
	"version": "1.0.7",
	"description": "Obsidian plugin for syncing reMarkable documents",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && cp manifest.json styles.css release/remarkable-sync/",
		"lint": "eslint \"src/**/*.ts\"",
		"typecheck": "tsc -noEmit -skipLibCheck",
		"test": "npx tsx run-sync.ts",
		"test:unit": "npx tsx --test src/*.test.ts"
	},
	"keywords": [],
	"author": "Tim Dommett",
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/parser": "^8.0.0",
		"canvas": "^3.2.1",
		"esbuild": "0.17.3",
		"eslint": "^9.0.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"mupdf": "^1.27.0",
		"obsidian": "latest",
		"pdfjs-dist": "^5.4.624",
		"ts-node": "^10.9.2",
		"tslib": "2.4.0",
		"tsx": "^4.21.0",
		"typescript": "5.4.5"
	},
	"dependencies": {
		"pdf-lib": "^1.17.1"
	}
}
